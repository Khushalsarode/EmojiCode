{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "emojicode",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "redis": true,
    "reddit": {
      "enable": true,
      "asUser": ["SUBMIT_POST", "SUBMIT_COMMENT"]
    }
  },
  "menu": {
    "items": [
      {
        "label": "Open EmojiCode",
        "description": "Go to the EmojiCode home hub — create a cipher, check rewards, view the leaderboard",
        "location": "subreddit",
        "forUserType": "user",
        "endpoint": "/internal/menu/open-submit-form"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install",
    "onCommentSubmit": "/internal/triggers/on-comment-submit"
  },
  "scheduler": {
    "tasks": {
      "leaderboard-digest": {
        "endpoint": "/internal/cron/leaderboard-digest",
        "cron": "0 0 * * 0"
      },
      "daily-cipher": {
        "endpoint": "/internal/cron/daily-cipher",
        "cron": "0 0 * * *"
      }
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "emojicode_dev"
  }
}
